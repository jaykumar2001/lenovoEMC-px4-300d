+static void
+rtl8168_wait_ll_share_fifo_ready(struct net_device *dev)
+{
+    struct rtl8168_private *tp = netdev_priv(dev);
+    void __iomem *ioaddr = tp->mmio_addr;
+    int i;
+
+    for (i = 0; i < 10; i++) {
+        udelay(100);
+        if (RTL_R16(0xD2) & BIT_9)
+            break;
+    }
+}
