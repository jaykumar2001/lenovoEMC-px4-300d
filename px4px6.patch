+#endif
+#else
+    .ndo_fix_features   = rtl8168_fix_features,
+    .ndo_set_features   = rtl8168_set_features,
+#endif
+#ifdef CONFIG_NET_POLL_CONTROLLER
+    .ndo_poll_controller    = rtl8168_netpoll,
+#endif
