+
+static void Dash2DisableTxRx(struct net_device *dev)
+{
+    struct rtl8168_private *tp = netdev_priv(dev);
+
+    if( HW_DASH_SUPPORT_TYPE_2( tp ) ) {
+        Dash2DisableTx( tp );
+        Dash2DisableRx( tp );
+    }
