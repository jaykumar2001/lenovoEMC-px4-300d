+void Dash2EnableTx(struct rtl8168_private *tp)
+{
+    void __iomem *ioaddr = tp->mmio_addr;
+
+    if (!tp->DASH) return;
+
+    if( HW_DASH_SUPPORT_TYPE_2( tp ) )
+        RTL_W8(IBCR2, RTL_R8(IBCR2) | BIT_0);
+}
