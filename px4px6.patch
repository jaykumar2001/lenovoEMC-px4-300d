+static void
+rtl8168_enable_rxdvgate(struct net_device *dev)
+{
+    struct rtl8168_private *tp = netdev_priv(dev);
+    void __iomem *ioaddr = tp->mmio_addr;
+
+    switch (tp->mcfg) {
+    case CFG_METHOD_21:
+    case CFG_METHOD_22:
+    case CFG_METHOD_23:
+    case CFG_METHOD_24:
+    case CFG_METHOD_25:
+    case CFG_METHOD_26:
+    case CFG_METHOD_27:
+    case CFG_METHOD_28:
+        RTL_W8(0xF2, RTL_R8(0xF2) | BIT_3);
+        mdelay(2);
+        break;
+    }
+}
+
+static void
+rtl8168_disable_rxdvgate(struct net_device *dev)
+{
+    struct rtl8168_private *tp = netdev_priv(dev);
+    void __iomem *ioaddr = tp->mmio_addr;
+
+    switch (tp->mcfg) {
+    case CFG_METHOD_21:
+    case CFG_METHOD_22:
+    case CFG_METHOD_23:
+    case CFG_METHOD_24:
+    case CFG_METHOD_25:
+    case CFG_METHOD_26:
+    case CFG_METHOD_27:
+    case CFG_METHOD_28:
+        RTL_W8(0xF2, RTL_R8(0xF2) & ~BIT_3);
+        mdelay(2);
+        break;
+    }
+}
