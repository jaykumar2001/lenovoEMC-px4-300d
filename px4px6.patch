+		sdev_power_state = sdev->sdev_power_state;
+		sdev->sdev_power_state = SDEV_PW_ON;
+		spin_unlock(sdev->host->host_lock);
+		if (sdev->standby_timeout_secs > 0) {
+			/* if the device had any standby timer */
+			standby_delete_timer(sdev);
