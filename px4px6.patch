+static int
+rtl8168_rx_vlan_skb(struct rtl8168_private *tp,
+                    struct RxDesc *desc,
+                    struct sk_buff *skb)
+{
+    u32 opts2 = le32_to_cpu(desc->opts2);
+    int ret = -1;
