+#define LCD_SCL		      	(1 << 7)  /* GPIO 7 */
+#define SYS_REBUILD     	(1 << 12) /* GPIO 12 */
+#define SYS_HEALTH      	(1 << 13) /* GPIO 13 */
+#define LCD_RS		      	(1 << 16) /* GPIO 16 */
+#define LCD_A0		        (1 << 19) /* GPIO 19 */
