+rtl8168_get_strings(struct net_device *dev,
+                    u32 stringset,
+                    u8 *data)
+{
+    switch (stringset) {
+    case ETH_SS_STATS:
+        memcpy(data, *rtl8168_gstrings, sizeof(rtl8168_gstrings));
+        break;
+    }
+}
