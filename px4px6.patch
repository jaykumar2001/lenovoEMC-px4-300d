+                               swab16(opts2 & 0xffff));
+        ret = 0;
+    }
+#elif LINUX_VERSION_CODE < KERNEL_VERSION(3,10,0)
+    if (opts2 & RxVlanTag)
+        __vlan_hwaccel_put_tag(skb, swab16(opts2 & 0xffff));
+#else
+    if (opts2 & RxVlanTag)
+        __vlan_hwaccel_put_tag(skb, htons(ETH_P_8021Q), swab16(opts2 & 0xffff));
+#endif
+
+    desc->opts2 = 0;
+    return ret;
+}
