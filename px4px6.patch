+    RxCfgDMAShift = 8,
+    RxCfg_128_int_en = (1 << 15),
+    RxCfg_fet_multi_en = (1 << 14),
+    RxCfg_half_refetch = (1 << 13),
+    RxCfg_9356SEL = (1 << 6),
