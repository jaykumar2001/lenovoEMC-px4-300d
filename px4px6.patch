+static void
+rtl8168_link_option(int idx,
+                    u8 *aut,
+                    u16 *spd,
+                    u8 *dup)
+{
+    if ((*spd != SPEED_1000) && (*spd != SPEED_100) && (*spd != SPEED_10))
+        *spd = SPEED_1000;
+
+    if ((*dup != DUPLEX_FULL) && (*dup != DUPLEX_HALF))
+        *dup = DUPLEX_FULL;
+
+    if ((*aut != AUTONEG_ENABLE) && (*aut != AUTONEG_DISABLE))
+        *aut = AUTONEG_ENABLE;
+}
