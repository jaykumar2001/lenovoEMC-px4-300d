+static void
+rtl8168_set_rx_mode(struct net_device *dev)
+{
+    struct rtl8168_private *tp = netdev_priv(dev);
+    unsigned long flags;
+
+    spin_lock_irqsave(&tp->lock, flags);
+
+    rtl8168_hw_set_rx_packet_filter(dev);
+
+    spin_unlock_irqrestore(&tp->lock, flags);
+}
